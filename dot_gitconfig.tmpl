[init]
	defaultBranch = main
	templateDir = ~/.config/git/templates

[user]
	signingkey = ~/.ssh/id_rsa.pub

[includeIf "hasconfig:remote.*.url:git@github.com*/**"]
	path = .gitconfig-github

[includeIf "hasconfig:remote.*.url:git@gitlab.com*/**"]
	path = .gitconfig-gitlab

[includeIf "hasconfig:remote.*.url:git@gitlab.devops.telekom.de*/**"]
	path = .gitconfig-work

[includeIf "hasconfig:remote.*.url:https://github.com/**"]
	path = .gitconfig-github

[includeIf "hasconfig:remote.*.url:https://gitlab.com/**"]
	path = .gitconfig-gitlab

[includeIf "hasconfig:remote.*.url:https://gitlab.devops.telekom.de/**"]
	path = .gitconfig-work

[gpg]
	format = ssh

[commit]
	gpgsign = true

[format]
	signoff = true

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[rebase]
	autoStash = true

[fetch]
	prune = true

[rerere]
	enabled = true
	autoUpdate = true

[diff]
	tool = difft
	colorMoved = default

[difftool]
	prompt = false

[difftool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""

[difftool "difft"]
	cmd = difft --display=side-by-side "$LOCAL" "$REMOTE"
	trustExitCode = true

[alias]
	diffd = difftool --dir-diff

[merge]
	tool = nvimdiff

[mergetool]
	prompt = true

[mergetool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\" \"$MERGED\" -c 'wincmd w' -c 'wincmd J'"

[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[credential "https://gitlab.devops.telekom.de"]
{{- $glab := lookPath "glab" }}
{{- if $glab }}
	helper = !{{ $glab }} auth git-credential
{{- end }}
