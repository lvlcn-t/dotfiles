#!/usr/bin/env bash
# Global pre-commit hook.
# Run gitleaks on staged changes unless the repo already
# configures gitleaks via .pre-commit-config.yaml.

set -euo pipefail

# If gitleaks is already managed by pre-commit config, skip
if [ -f .pre-commit-config.yaml ] &&
  grep -q 'gitleaks' .pre-commit-config.yaml 2>/dev/null; then
  exit 0
fi

# Require gitleaks to be installed
if ! command -v gitleaks &>/dev/null; then
  echo "gitleaks not found -- skipping secret scan"
  exit 0
fi

gitleaks protect --staged --verbose
